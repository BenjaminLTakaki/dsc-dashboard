# ─────────────────────────────────────────────────────────────────
# FIWARE DSC Dashboard — environment configuration
# Copy this file to .env and edit the values for your setup.
# ─────────────────────────────────────────────────────────────────

# Port the dashboard HTTP server listens on (default: 5000)
PORT=5000

# Absolute or relative path to the root of the data-space-connector repo.
# Default assumes dsc-dashboard/ and data-space-connector/ are siblings:
#   g:\FinalFiware\
#     ├── dsc-dashboard\      ← you are here
#     └── data-space-connector\
#
# If your layout differs, set this to the correct absolute path.
# Windows example:  PROJECT_ROOT=C:\projects\data-space-connector
# Linux/WSL2:       PROJECT_ROOT=/home/user/data-space-connector
#PROJECT_ROOT=../data-space-connector

# Directory containing did.json and private-key.pem (created by the Generate DID step).
# Defaults to $PROJECT_ROOT/cert — override only if you keep the cert files elsewhere.
#CERT_DIR=../data-space-connector/cert

# Squid proxy used to reach HTTPS services (Keycloak, VCVerifier) inside K3s.
# The K3s deployment exposes a Squid proxy on port 8888 of the host machine.
# Set to an empty string to disable proxy (direct HTTPS — TLS check is already off).
# Multi-VM example: SQUID_PROXY=http://192.168.133.13:8888
SQUID_PROXY=http://localhost:8888
